# Docker Compose variables (used by docker-compose.yml)
POSTGRES_USER=fintech_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=fintech_db
JWT_SECRET=change_this_to_a_random_secret_min_32_chars

# Backend .env variables
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=fintech_user
DATABASE_PASSWORD=change_this_password
DATABASE_NAME=fintech_db
JWT_EXPIRATION=24h

# Application Configuration
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
